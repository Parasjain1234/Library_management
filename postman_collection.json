{
	"info": {
		"_postman_id": "library-management-api",
		"name": "Library Management System API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Get All Books",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/books",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books"]
				}
			}
		},
		{
			"name": "Add New Book",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"The Great Gatsby\",\n  \"author\": \"F. Scott Fitzgerald\",\n  \"isbn\": \"978-0-7432-7356-5\",\n  \"genre\": \"Fiction\",\n  \"publisher\": \"Scribner\",\n  \"publicationYear\": 1925,\n  \"totalCopies\": 5,\n  \"availableCopies\": 3,\n  \"shelfLocation\": \"A1-101\",\n  \"bookType\": \"Circulating\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/books",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books"]
				}
			}
		},
		{
			"name": "Get Book by ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/books/:id",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books", ":id"]
				}
			}
		},
		{
			"name": "Update Book",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"The Great Gatsby (Updated Edition)\",\n  \"availableCopies\": 4\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/books/:id",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books", ":id"]
				}
			}
		},
		{
			"name": "Delete Book",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/books/:id",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books", ":id"]
				}
			}
		},
		{
			"name": "Search Books by Title",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/books/search?title=Great",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books", "search"],
					"query": [
						{
							"key": "title",
							"value": "Great"
						}
					]
				}
			}
		},
		{
			"name": "Search Books by Author",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/books/search?author=Fitzgerald",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books", "search"],
					"query": [
						{
							"key": "author",
							"value": "Fitzgerald"
						}
					]
				}
			}
		}
	]
}
